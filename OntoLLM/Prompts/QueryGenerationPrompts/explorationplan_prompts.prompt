Given the following ontology structure:

{
    "nodes": {
      "Well": {
        "WellName": "Text"
      },
      "Block": {
        "BlockNumber": "Text"
      },
      "Area": {
        "AreaName": "Text"
      },
      "Lease": {
        "LeaseNumber": "Text"
      },
      "Region": {
        "RegionName": "Text"
      },
      "ExplorationPlan": {
        "ControlNumber": "Text",
        "Type": "Text",
        "DateReceived": "Date"
      },
      "Question": {
        "ChunkVectorRefID": "Numeric",
        "ChunkQuestion": "Text"
      }
    },
    "relationtrees": {
      "relations": [
        "(RG:REGION)-[ha:hasArea]-(AR:Area)",
        "(AR:Area)-[hb:hasBlock]-(BL:Block)",
        "(BL:Block)-[hw:hasWell]-(WL:Well)",
        "(BL:Block)-[hl:hasLease]-(LS:Lease)",
        "(BL:Block)-[hep:hasExplorationPlan]-(EP:ExplorationPlan)",
        "(EP:ExplorationPlan)-[hq:hasQuestions]-(Q:Question)",
        "(Q:Question)-[r:related]-(Q2:Question)"
      ]      
    }
}

Here are example queries mapping natural-language questions to graph (Cypher-style) queries:

Natural Query: "Get the exploration plan with ControlNumber = #ent1."
KG Query: "MATCH (ep:ExplorationPlan {ControlNumber: '#ent1'}) RETURN ep.ControlNumber, ep.Type, ep.DateReceived"

Natural Query: "List wells in Block = #ent1."
KG Query: "MATCH (bl:Block {BlockNumber: '#ent1'})-[:hw:hasWell]->(wl:Well) RETURN wl.WellName"

Natural Query: "List blocks in Area = #ent1."
KG Query: "MATCH (ar:Area {AreaName: '#ent1'})-[:hb:hasBlock]->(bl:Block) RETURN bl.BlockNumber"

Natural Query: "List leases for Block = #ent1."
KG Query: "MATCH (bl:Block {BlockNumber: '#ent1'})-[:hl:hasLease]->(ls:Lease) RETURN ls.LeaseNumber"

Natural Query: "Get exploration plans of Type = #ent1 in Region = #ent2."
KG Query: "MATCH (rg:Region {RegionName: '#ent2'})-[:ha:hasArea]->(ar:Area)-[:hb:hasBlock]->(bl:Block)-[:hep:hasExplorationPlan]->(ep:ExplorationPlan {Type: '#ent1'}) RETURN ep.ControlNumber, ep.DateReceived"

Natural Query: "Show questions for ExplorationPlan with ControlNumber = #ent1."
KG Query: "MATCH (ep:ExplorationPlan {ControlNumber: '#ent1'})-[:hq:hasQuestions]->(q:Question) RETURN q.ChunkQuestion"
